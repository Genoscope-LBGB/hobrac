# Container versions
HOBRAC_TOOLS = "docker://ghcr.io/cea-lbgb/hobrac-tools:0.1.8"


# Constraining the wildcard keeps it from matching greedily across '/'
# when a rule references a file inside a directory() output
# (e.g. aln/busco_{accession}/aln_busco.paf).
wildcard_constraints:
    accession=r"[^/]+",


def get_pipeline_targets(wildcards):
    checkpoint_output = checkpoints.select_references.get(**wildcards).output[0]

    accessions = []
    with open(checkpoint_output) as f:
        for line in f:
            if line.strip():
                accessions.append(line.strip())

    target_patterns = ["aln/busco_{accession}"]
    if not config.get("skip_genomic", False):
        target_patterns.append("aln/vs_{accession}/dgenies.done")

    targets = expand(target_patterns, accession=accessions)

    if not config.get("manual_references"):
        targets.append("aln/ranking_symlinks.done")

    targets.append("synteny_plots/karyotype.png")

    # Per-reference ALG-colored dotplots (assembly on Y, each reference on X).
    targets.extend(
        expand(
            [
                "synteny_plots/dotplots/{accession}.png",
                "synteny_plots/dotplots/{accession}_dark.png",
            ],
            accession=accessions,
        )
    )

    # Combined grid of all per-reference dotplots, titled by species.
    targets.append("synteny_plots/dotplots_grid.png")
    targets.append("synteny_plots/dotplots_grid_dark.png")

    return targets


def get_targets(wildcards):
    if config.get("stop_after_mash", False):
        return ["mash/mash.dist"]

    return get_pipeline_targets(wildcards) + ["aln/cleanup.done"]


include: "rules/mash.smk"
include: "rules/references.smk"
include: "rules/busco.smk"
include: "rules/aln.smk"
include: "rules/jcvi.smk"


rule all:
    input:
        get_targets,
    resources:
        runtime=30,

