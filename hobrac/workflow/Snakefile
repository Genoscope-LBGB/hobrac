# Container versions
HOBRAC_TOOLS = "docker://ghcr.io/cea-lbgb/hobrac-tools:0.1.7"


def get_pipeline_targets(wildcards):
    checkpoint_output = checkpoints.select_references.get(**wildcards).output[0]

    accessions = []
    with open(checkpoint_output) as f:
        for line in f:
            if line.strip():
                accessions.append(line.strip())

    targets = expand(
        ["aln/busco_{accession}", "aln/vs_{accession}/dgenies.done"],
        accession=accessions,
    )

    if not config.get("manual_references"):
        targets.append("aln/ranking_symlinks.done")

    targets.append("aln/jcvi_karyotype/karyotype.png")

    return targets


def get_targets(wildcards):
    if config.get("stop_after_mash", False):
        return ["mash/mash.dist"]

    return get_pipeline_targets(wildcards) + ["aln/cleanup.done"]


include: "rules/mash.smk"
include: "rules/references.smk"
include: "rules/busco.smk"
include: "rules/aln.smk"
include: "rules/jcvi.smk"


rule all:
    input:
        get_targets,
